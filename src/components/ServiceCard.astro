---
// ServiceCard — imagen + icono SVG + título + <ul> subservicios
// Uso: <ServiceCard image="/path.jpg"><svg slot="icon">...</svg><span slot="title">...</span><ul slot="services">...</ul></ServiceCard>
---

<div class="card">
  {
    Astro.slots.has('image') && (
      <div class="card__image">
        <slot name="image" />
      </div>
    )
  }
  <div class="card__body">
    <div class="card__icon">
      <slot name="icon" />
    </div>
    <h3 class="card__title"><slot name="title" /></h3>
    <div class="card__services">
      <slot name="services" />
    </div>
  </div>
</div>

<style>
  .card {
    background: var(--clr-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--clr-border);
    display: flex;
    flex-direction: column;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--clr-accent);
  }

  .card__image {
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .card__image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-base);
  }

  .card:hover .card__image :global(img) {
    transform: scale(1.05);
  }

  .card__body {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    flex: 1;
  }

  .card__icon {
    width: 56px;
    height: 56px;
    color: var(--clr-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .card__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: var(--font-weight-semibold);
    color: var(--clr-primary);
  }

  .card__services :global(ul) {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .card__services :global(li) {
    padding: var(--spacing-xs) 0 var(--spacing-xs) 1.5rem;
    position: relative;
    font-size: 0.9375rem;
    color: var(--clr-text-muted);
  }

  .card__services :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--clr-accent);
  }
</style>
