---
// WhatsAppButton — CTA header con ícono SVG + enlace a WhatsApp
import IconWhatsApp from './IconWhatsApp.astro';
---

<a
  href="https://wa.me/573025330660"
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-btn btn btn--whatsapp"
  aria-label="Solicitar asistencia por WhatsApp"
>
  <IconWhatsApp size={20} />
  <span>Solicitar Asistencia</span>
</a>

<style>
  .whatsapp-btn {
    white-space: nowrap;
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    gap: var(--spacing-xs);
  }

  @media (max-width: 767px) {
    .whatsapp-btn span {
      display: none;
    }

    .whatsapp-btn {
      padding: 0.5rem;
    }
  }
</style>
