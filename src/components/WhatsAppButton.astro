---
// WhatsAppButton — CTA header que redirige a la sección de contacto
---

<a
  href="#contacto"
  class="whatsapp-btn btn btn--whatsapp"
  aria-label="Ir a la sección de contacto"
>
  <span>Solicitar Asistencia</span>
</a>

<style>
  .whatsapp-btn {
    white-space: nowrap;
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    gap: var(--spacing-xs);
  }

  @media (max-width: 767px) {
    .whatsapp-btn span {
      display: none;
    }

    .whatsapp-btn {
      padding: 0.5rem;
    }
  }
</style>
