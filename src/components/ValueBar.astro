---
// ValueBar — 4 ValuePillar en fila horizontal / stack vertical, bg #0a1931
import ValuePillar from './ValuePillar.astro';
---

<section class="value-bar section--dark" aria-label="Nuestros valores">
  <div class="container">
    <div class="value-bar__grid">
      <ValuePillar>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9" />
          <polyline points="12,7 12,12 16,14" />
        </svg>
        <span slot="title">Atención Inmediata 24/7</span>
      </ValuePillar>

      <ValuePillar>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          <polyline points="9,12 11,14 15,10" />
        </svg>
        <span slot="title">Seguridad y Confianza</span>
      </ValuePillar>

      <ValuePillar>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M8 12l3 3 5-5" />
        </svg>
        <span slot="title">Calidad Garantizada</span>
      </ValuePillar>

      <ValuePillar>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        <span slot="title">Equipo Profesional</span>
      </ValuePillar>
    </div>
  </div>
</section>

<style>
  .value-bar {
    padding-block: var(--spacing-lg);
  }

  .value-bar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);
  }

  @media (max-width: 767px) {
    .value-bar__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-md);
    }
  }
</style>
