---
// Hero — full-bleed bg image con overlay gradiente, texto sobrepuesto a la izquierda
// "Inmediatas" destacado en --clr-accent (#d4a017)
import IconWhatsApp from './IconWhatsApp.astro';
---

<section class="hero" id="inicio">
  <div class="hero__bg">
    <picture>
      <source srcset="/images/hero.webp" type="image/webp" />
      <img
        src="/images/hero.jpg"
        alt=""
        loading="eager"
        decoding="async"
      />
    </picture>
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__content container">
    <h1 class="hero__title">
      Soluciones <span class="hero__highlight">Inmediatas</span>,<br />
      Resultados Duraderos
    </h1>
    <p class="hero__subtitle">
      Expertos en servicios generales para hogares y empresas en el Área Metropolitana de Bucaramanga.
      Atención profesional 24/7.
    </p>
    <div class="hero__actions">
      <a
        href="https://wa.me/573025330660"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--whatsapp"
        aria-label="Escríbenos por WhatsApp"
      >
        <IconWhatsApp size={20} />
        Escríbenos
      </a>
      <a href="#servicios" class="btn btn--outline">
        Qué Ofrecemos
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    color: var(--clr-white);
    overflow: hidden;
    min-height: 85vh;
    scroll-margin-top: 80px;
  }

  /* === Background image === */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg picture,
  .hero__bg img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  /* === Gradient overlay === */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(10, 25, 49, 1)   0%,
      rgba(10, 25, 49, .85) 30%,
      rgba(10, 25, 49, .4)  55%,
      rgba(10, 25, 49, .1)  80%,
      transparent            100%
    );
  }

  /* === Content on top === */
  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 85vh;
    padding-top: calc(64px + var(--spacing-xl));
    padding-bottom: var(--spacing-xl);
    align-items: flex-start;
  }

  .hero__title {
    margin: 0 0 var(--spacing-md);
    line-height: 1.1;
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    text-align: left;
    max-width: 820px;
  }

  .hero__highlight {
    color: var(--clr-accent);
  }

  .hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    opacity: 0.9;
    margin: 0 0 var(--spacing-lg);
    max-width: 32em;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  /* === Tablet / mobile: overlay más denso, texto centrado === */
  @media (max-width: 900px) {
    .hero__overlay {
      background: linear-gradient(
        to right,
        rgba(10, 25, 49, 1)   0%,
        rgba(10, 25, 49, .9)  40%,
        rgba(10, 25, 49, .6)  70%,
        transparent            100%
      );
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: auto;
    }

    .hero__content {
      min-height: auto;
      align-items: center;
      text-align: center;
      max-width: none;
      padding-top: calc(64px + var(--spacing-lg));
      padding-bottom: var(--spacing-lg);
    }

    .hero__title {
      text-align: center;
    }

    .hero__subtitle {
      max-width: none;
    }

    /* Oculta el botón de WhatsApp del hero en mobile */
    .hero__actions .btn--whatsapp {
      display: none;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__overlay {
      background: linear-gradient(
        to bottom,
        rgba(10, 25, 49, .3)  0%,
        rgba(10, 25, 49, .85) 50%,
        rgba(10, 25, 49, 1)   100%
      );
    }
  }
</style>
