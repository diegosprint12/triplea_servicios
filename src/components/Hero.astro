---
// Hero — full-bleed bg image con overlay gradiente, texto sobrepuesto a la izquierda
// "Inmediatas" destacado en --clr-accent (#d4a017)
---

<section class="hero" id="inicio">
  <div class="hero__bg">
    <picture>
      <source srcset="/images/hero.webp" type="image/webp" />
      <img
        src="/images/hero.jpg"
        alt=""
        loading="eager"
        decoding="async"
      />
    </picture>
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__content container">
    <h1 class="hero__title">
      Soluciones <span class="hero__highlight">Inmediatas</span>,<br />
      Resultados Duraderos
    </h1>
    <p class="hero__subtitle">
      Expertos en servicios generales para hogares y empresas en Bucaramanga.
      Atención profesional 24/7.
    </p>
    <div class="hero__actions">
      <a
        href="https://wa.me/573025330660"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--whatsapp"
        aria-label="Escríbenos por WhatsApp"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Escríbenos
      </a>
      <a href="#servicios" class="btn btn--outline">
        Solicitar Asistencia
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    color: var(--clr-white);
    overflow: hidden;
    min-height: 85vh;
  }

  /* === Background image === */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg picture,
  .hero__bg img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  /* === Gradient overlay === */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(10, 25, 49, 1)   0%,
      rgba(10, 25, 49, .85) 30%,
      rgba(10, 25, 49, .4)  55%,
      rgba(10, 25, 49, .1)  80%,
      transparent            100%
    );
  }

  /* === Content on top === */
  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 85vh;
    padding-top: calc(64px + var(--spacing-xl));
    padding-bottom: var(--spacing-xl);
    max-width: 640px;
  }

  .hero__title {
    margin: 0 0 var(--spacing-md);
    line-height: 1.1;
  }

  .hero__highlight {
    color: var(--clr-accent);
  }

  .hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    opacity: 0.9;
    margin: 0 0 var(--spacing-lg);
    max-width: 32em;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  /* === Tablet / mobile: overlay más denso, texto centrado === */
  @media (max-width: 900px) {
    .hero__overlay {
      background: linear-gradient(
        to right,
        rgba(10, 25, 49, 1)   0%,
        rgba(10, 25, 49, .9)  40%,
        rgba(10, 25, 49, .6)  70%,
        transparent            100%
      );
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: auto;
    }

    .hero__content {
      min-height: auto;
      align-items: center;
      text-align: center;
      max-width: none;
      padding-top: calc(64px + var(--spacing-lg));
      padding-bottom: var(--spacing-lg);
    }

    .hero__subtitle {
      max-width: none;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__overlay {
      background: linear-gradient(
        to bottom,
        rgba(10, 25, 49, .3)  0%,
        rgba(10, 25, 49, .85) 50%,
        rgba(10, 25, 49, 1)   100%
      );
    }
  }
</style>
