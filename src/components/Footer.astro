---
// Footer — bg #0a1931, logo izquierda + línea separadora + 3 columnas
import FooterLogo from './FooterLogo.astro';
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__main">
      <div class="footer__brand">
        <FooterLogo />
      </div>
      <div class="footer__divider" role="separator" aria-hidden="true"></div>
      <div class="footer__grid">
        <!-- Columna 1: Navegación -->
        <div class="footer__col">
          <h4 class="footer__heading">Navegación</h4>
          <ul class="footer__list footer__list--nav" role="list">
            <li><a href="#inicio">Inicio</a></li>
            <li><a href="#servicios">Servicios</a></li>
            <li><a href="#nosotros">Nosotros</a></li>
            <li><a href="#proyectos">Proyectos</a></li>
            <li><a href="#contacto">Contacto</a></li>
          </ul>
        </div>

        <!-- Columna 2: Servicios -->
        <div class="footer__col">
          <h4 class="footer__heading">Servicios</h4>
          <ul class="footer__list footer__list--services" role="list">
            <li>Servicios Generales</li>
            <li>Mantenimiento Residencial</li>
            <li>Instalaciones Técnicas</li>
            <li>Emergencias 24/7</li>
          </ul>
        </div>

        <!-- Columna 3: Contacto -->
        <div class="footer__col">
          <h4 class="footer__heading">Contacto</h4>
          <ul class="footer__list footer__list--contact" role="list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <span>Área Metropolitana de Bucaramanga</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <a href="https://wa.me/573025330660" target="_blank" rel="noopener noreferrer">302 5330660</a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} AAA Servicios Generales. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--clr-primary);
    color: var(--clr-text-on-dark);
    padding-block: var(--spacing-xl) var(--spacing-lg);
  }

  .footer__main {
    display: flex;
    gap: var(--spacing-xl);
    align-items: flex-start;
  }

  .footer__brand {
    flex-shrink: 0;
    width: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm) 0;
  }

  .footer__divider {
    width: 1px;
    align-self: stretch;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.02),
      rgba(255, 255, 255, 0.15) 30%,
      rgba(255, 255, 255, 0.15) 70%,
      rgba(255, 255, 255, 0.02)
    );
    flex-shrink: 0;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--spacing-xl);
    flex: 1;
  }

  .footer__heading {
    margin: 0 0 var(--spacing-md);
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    color: var(--clr-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .footer__list a,
  .footer__list li {
    color: var(--clr-text-on-dark);
    text-decoration: none;
    font-size: 0.9375rem;
    opacity: 0.85;
    transition: opacity var(--transition-fast), color var(--transition-fast);
    cursor: default;
  }

  .footer__list--services li {
    opacity: 0.85;
  }
  
  .footer__list--contact a {
    opacity: 1;
    color: #ffff;
  }

  .footer__list--nav a {
    cursor: pointer;
    opacity: 1;
    color: #ffff;
  }

  .footer__list--nav a:hover {
    opacity: 1;
    color: var(--clr-accent);
  }

  .footer__list--services li:hover,
  .footer__list--contact li:hover {
    opacity: 1;
    color: #dddd;
  }

  .footer__list--contact a:hover {
    opacity: 1;
    color: var(--clr-accent);
  }

  .footer__list--contact {
    gap: var(--spacing-md);
  }

  .footer__list--contact li {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .footer__list--contact li svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .footer__list--contact a {
    cursor: pointer;
  }

  .footer__bottom {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .footer__bottom p {
    margin: 0;
  }

  @media (max-width: 767px) {
    .footer__main {
      flex-direction: column;
      gap: var(--spacing-lg);
    }

    .footer__divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(
        to right,
        rgba(255, 255, 255, 0.02),
        rgba(255, 255, 255, 0.15) 30%,
        rgba(255, 255, 255, 0.15) 70%,
        rgba(255, 255, 255, 0.02)
      );
    }

    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .footer__brand {
      width: 100%;
      display: flex;
      justify-content: center;
      padding: var(--spacing-lg) 0;
    }
  }
</style>
