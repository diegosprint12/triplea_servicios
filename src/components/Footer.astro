---
// Footer — bg #0a1931, logo izquierda + línea separadora + 3 columnas
import FooterLogo from './FooterLogo.astro';
import IconWhatsApp from './IconWhatsApp.astro';
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__main">
      <div class="footer__brand">
        <FooterLogo />
        <div class="footer__brand-location">
          <svg class="contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <span>Área Metropolitana de Bucaramanga</span>
        </div>
        <div class="footer__brand-whatsapp">
          <IconWhatsApp size={18} color="var(--clr-accent)" />
          <a href="https://wa.me/573025330660" target="_blank" rel="noopener noreferrer">302 5330660</a>
        </div>
      </div>
      <div class="footer__divider" role="separator" aria-hidden="true"></div>
      <div class="footer__grid">
        <!-- Columna 1: Navegación -->
        <div class="footer__col">
          <h4 class="footer__heading">Navegación</h4>
          <ul class="footer__list footer__list--nav" role="list">
            <li><a href="#inicio">Inicio</a></li>
            <li><a href="#nosotros">Nosotros</a></li>
            <li><a href="#servicios">Servicios</a></li>
            <li><a href="#contacto">Contacto</a></li>
          </ul>
        </div>

        <!-- Columna 2: Servicios -->
        <div class="footer__col">
          <h4 class="footer__heading">Servicios</h4>
          <ul class="footer__list footer__list--services" role="list">
            <li>Servicios Generales</li>
            <li>Mantenimiento Residencial</li>
          </ul>
        </div>

        <!-- Columna 3: Contacto -->
        <div class="footer__col">
          <h4 class="footer__heading">Contacto</h4>
          <ul class="footer__list footer__list--contact" role="list">
            <li>
              <svg class="contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span>Área Metropolitana de Bucaramanga</span>
            </li>
            <li>
              <span class="contact-icon"><IconWhatsApp size={18} color="var(--clr-accent)" /></span>
              <a href="https://wa.me/573025330660" target="_blank" rel="noopener noreferrer">302 5330660</a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} AAA Servicios Generales. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--clr-primary);
    color: var(--clr-text-on-dark);
    padding-block: var(--spacing-xl) var(--spacing-lg);
  }

  .footer__main {
    display: flex;
    gap: var(--spacing-xl);
    align-items: flex-start;
  }

  .footer__brand {
    flex-shrink: 0;
    width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm) 0;
  }

  .footer__brand-location {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-sm);
    font-size: 0.875rem;
    color: var(--clr-text-on-dark);
    opacity: 0.85;
  }

  .footer__brand-location svg {
    flex-shrink: 0;
    color: var(--clr-accent);
  }

  .footer__brand-whatsapp {
    display: none;
  }

  .footer__divider {
    width: 1px;
    align-self: stretch;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.02),
      rgba(255, 255, 255, 0.15) 30%,
      rgba(255, 255, 255, 0.15) 70%,
      rgba(255, 255, 255, 0.02)
    );
    flex-shrink: 0;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: var(--spacing-xl);
    flex: 1;
  }

  .footer__heading {
    margin: 0 0 var(--spacing-md);
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    color: var(--clr-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .footer__list a,
  .footer__list li {
    color: var(--clr-text-on-dark);
    text-decoration: none;
    font-size: 0.9375rem;
    opacity: 0.85;
    transition: opacity var(--transition-fast), color var(--transition-fast);
    cursor: default;
  }

  .footer__list--services li {
    opacity: 0.85;
  }
  
  .footer__list--contact a {
    opacity: 1;
    color: var(--clr-white);
  }

  .footer__list--nav a {
    cursor: pointer;
    opacity: 1;
    color: var(--clr-white);
  }

  .footer__list--nav a:hover {
    opacity: 1;
    color: var(--clr-accent);
  }

  .footer__list--services li:hover,
  .footer__list--contact li:hover {
    opacity: 1;
    color: #ddd;
  }

  .footer__list--contact a:hover {
    opacity: 1;
    color: var(--clr-accent);
  }

  .footer__list--contact {
    gap: var(--spacing-md);
  }

  .footer__list--contact li {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    white-space: nowrap;
  }

  .footer__list--contact li .contact-icon {
    flex-shrink: 0;
    color: var(--clr-accent);
  }

  .footer__list--contact a {
    cursor: pointer;
  }

  .footer__bottom {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .footer__bottom p {
    margin: 0;
  }

  @media (max-width: 767px) {
    .footer__main {
      flex-direction: column;
      gap: var(--spacing-lg);
    }

    .footer__divider {
      display: none;
    }

    .footer__grid {
      display: none;
    }

    .footer__brand {
      width: 100%;
      display: flex;
      justify-content: center;
      padding: var(--spacing-lg) 0;
    }

    .footer__brand-location {
      font-size: 0.9rem;
    }

    .footer__brand-whatsapp {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--spacing-sm);
      margin-top: var(--spacing-xs);
      font-size: 0.875rem;
      color: var(--clr-accent);
    }

    .footer__brand-whatsapp svg {
      flex-shrink: 0;
    }

    .footer__brand-whatsapp a {
      color: var(--clr-text-on-dark);
      text-decoration: none;
      opacity: 0.85;
    }
  }
</style>
