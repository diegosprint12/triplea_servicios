---
// ServiciosSection — 4 ServiceCard en grid 2×2 / 1 col mobile, bg #ffffff
import ServiceCard from './ServiceCard.astro';
---

<section class="servicios section" id="servicios" aria-label="Nuestros servicios">
  <div class="container">
    <h2 class="section__title section__title--yellow">NUESTROS SERVICIOS</h2>
    <div class="servicios__header">
      <p class="servicios__subtitle">SOLUCIONES PARA CADA NECESIDAD</p>
      <div class="servicios__divider" aria-hidden="true"></div>
    </div>
    <div class="servicios__grid">
      <ServiceCard>
        <img slot="image" src="/images/servicios/generales.jpg" alt="Herramientas de reparación" loading="lazy" />
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
        </svg>
        <span slot="title">Servicios Generales</span>
        <ul slot="services">
          <li>Plomería</li>
          <li>Electricidad</li>
          <li>Pintura</li>
          <li>Limpieza</li>
        </ul>
      </ServiceCard>

      <ServiceCard>
        <img slot="image" src="/images/servicios/mantenimiento.jpg" alt="Jardinería y mantenimiento" loading="lazy" />
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        <span slot="title">Mantenimiento Residencial</span>
        <ul slot="services">
          <li>Jardinería</li>
          <li>Carpintería</li>
          <li>Reparaciones</li>
          <li>Impermeabilización</li>
        </ul>
      </ServiceCard>
    </div>
  </div>
</section>

<style>
  .section__title--yellow {
    color: var(--clr-accent);
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    letter-spacing: 3px;
    margin-bottom: var(--spacing-sm);
  }

  .servicios__header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .servicios__subtitle {
    font-size: clamp(1.3rem, 3.5vw, 2rem);
    font-weight: var(--font-weight-bold);
    color: var(--clr-primary);
    margin: 0;
    max-width: 700px;
    letter-spacing: 1px;
  }

  .servicios__divider {
    width: 80px;
    height: 4px;
    background: var(--clr-accent);
    border-radius: 2px;
  }

  .servicios__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .servicios {
    padding-bottom: calc(var(--spacing-xl) + 3rem);
  }

  @media (max-width: 767px) {
    .servicios__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
