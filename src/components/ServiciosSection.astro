---
// ServiciosSection — 4 ServiceCard en grid 2×2 / 1 col mobile, bg #ffffff
import ServiceCard from './ServiceCard.astro';
---

<section class="servicios section" id="servicios" aria-label="Nuestros servicios">
  <div class="container">
    <h2 class="section__title">Nuestros Servicios</h2>
    <p class="servicios__intro">
      Ofrecemos soluciones integrales para hogares y empresas en el Área Metropolitana de Bucaramanga.
    </p>
    <div class="servicios__grid">
      <ServiceCard>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
        </svg>
        <span slot="title">Servicios Generales</span>
        <ul slot="services">
          <li>Plomería</li>
          <li>Electricidad</li>
          <li>Pintura</li>
          <li>Limpieza</li>
        </ul>
      </ServiceCard>

      <ServiceCard>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        <span slot="title">Mantenimiento Residencial</span>
        <ul slot="services">
          <li>Jardinería</li>
          <li>Carpintería</li>
          <li>Reparaciones</li>
          <li>Impermeabilización</li>
        </ul>
      </ServiceCard>

      <ServiceCard>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="3" />
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />
        </svg>
        <span slot="title">Instalaciones Técnicas</span>
        <ul slot="services">
          <li>Aire Acondicionado</li>
          <li>CCTV</li>
          <li>Redes Eléctricas</li>
          <li>Alarmas</li>
        </ul>
      </ServiceCard>

      <ServiceCard>
        <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          <path d="M14 2a6 6 0 0 1 6 6" />
          <path d="M14 6a2 2 0 0 1 2 2" />
        </svg>
        <span slot="title">Emergencias 24/7</span>
        <ul slot="services">
          <li>Fugas de Agua</li>
          <li>Cortocircuitos</li>
          <li>Cerraduras</li>
          <li>Estructuras</li>
        </ul>
      </ServiceCard>
    </div>
  </div>
</section>

<style>
  .servicios__intro {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--spacing-lg);
    color: var(--clr-text-muted);
    font-size: 1.05rem;
  }

  .servicios__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  @media (max-width: 767px) {
    .servicios__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
