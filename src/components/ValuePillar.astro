---
// ValuePillar — icono SVG + texto para la ValueBar
// Uso: <ValuePillar><svg slot="icon">...</svg><span slot="title">Texto</span></ValuePillar>
---

<div class="pillar">
  <div class="pillar__icon">
    <slot name="icon" />
  </div>
  <p class="pillar__title"><slot name="title" /></p>
</div>

<style>
  .pillar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    text-align: center;
    padding: var(--spacing-md) var(--spacing-sm);
  }

  .pillar__icon {
    width: 48px;
    height: 48px;
    color: var(--clr-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pillar__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .pillar__title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
  }
</style>
