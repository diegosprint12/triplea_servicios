---
// BaseLayout — HTML shell con SEO, meta tags, Open Graph, JSON-LD
import '../styles/global.css';
import IconWhatsApp from '../components/IconWhatsApp.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'AAA Servicios Generales | Plomería, Electricidad y Mantenimiento en Área Metropolitana de Bucaramanga',
  description = 'Expertos en servicios generales en Bucaramanga, Girón, Floridablanca y Piedecuesta. Plomería, electricidad, pintura y mantenimiento. Atención 24/7.',
  ogImage = '/images/hero.webp',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a1931" />
    <meta name="format-detection" content="telephone=yes" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="AAA Servicios Generales" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href="https://tripleaservicios.vercel.app" />

    <!-- JSON-LD: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "AAA Servicios Generales",
      "description": "Expertos en servicios generales en Bucaramanga, Girón, Floridablanca y Piedecuesta. Plomería, electricidad, pintura y mantenimiento. Atención 24/7.",
      "url": "https://tripleaservicios.vercel.app",
      "telephone": "302 5330660",
      "image": "https://tripleaservicios.vercel.app/images/hero.webp",
      "priceRange": "$$",
      "areaServed": [
        "Área Metropolitana de Bucaramanga",
        "Girón",
        "Floridablanca",
        "Piedecuesta"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Acapulco",
        "addressLocality": "Girón",
        "addressRegion": "Santander",
        "addressCountry": "CO"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios Generales",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Plomería" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Electricidad" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pintura" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Limpieza" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Jardinería" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Carpintería" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparaciones" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Impermeabilización" } }
        ]
      }
    })} />

    <title>{title}</title>

    <!-- Fuentes tipográficas -->
  </head>
  <body>
    <slot />

    <!-- Floating WhatsApp button — solo visible en mobile -->
    <a
      href="https://wa.me/573025330660"
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-float"
      aria-label="Contáctanos por WhatsApp"
    >
      <IconWhatsApp size={28} />
    </a>



    <style>
      .whatsapp-float {
        display: none;
      }

      @media (max-width: 767px) {
        .whatsapp-float {
          display: flex;
          align-items: center;
          justify-content: center;
          position: fixed;
          bottom: 1.5rem;
          right: 1.5rem;
          z-index: 999;
          width: 60px;
          height: 60px;
          border-radius: 50%;
          background: #25d366;
          color: #fff;
          text-decoration: none;
          box-shadow: 0 4px 16px rgba(37, 211, 102, .4);
          animation: whatsapp-pulse 2s ease-in-out infinite;
          transition: transform .2s, box-shadow .2s;
        }

        .whatsapp-float:hover {
          transform: scale(1.1);
          box-shadow: 0 6px 24px rgba(37, 211, 102, .5);
        }

        .whatsapp-float:active {
          transform: scale(.95);
        }

        @keyframes whatsapp-pulse {
          0%   { box-shadow: 0 4px 16px rgba(37, 211, 102, .4); }
          50%  { box-shadow: 0 4px 28px rgba(37, 211, 102, .7); }
          100% { box-shadow: 0 4px 16px rgba(37, 211, 102, .4); }
        }
      }
    </style>
  </body>
</html>