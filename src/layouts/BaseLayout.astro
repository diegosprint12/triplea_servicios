---
// BaseLayout — HTML shell con SEO, meta tags, Open Graph, JSON-LD

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'AAA Servicios Generales | Soluciones Inmediatas, Resultados Duraderos',
  description = 'Servicios generales profesionales en Bucaramanga: plomería, electricidad, pintura y limpieza. Atención 24/7.',
  ogImage = '/images/hero.webp',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a1931" />
    <meta name="format-detection" content="telephone=yes" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="AAA Servicios Generales" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://aaaservicios.co" />

    <!-- JSON-LD: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "AAA Servicios Generales",
      "description": "Servicios generales profesionales: plomería, electricidad, pintura y limpieza. Atención 24/7.",
      "url": "https://aaaservicios.co",
      "telephone": "302 5330660",
      "areaServed": "Área Metropolitana de Bucaramanga",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bucaramanga",
        "addressCountry": "CO"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      }
    })} />

    <title>{title}</title>

    <!-- System fonts — sin Google Fonts por performance -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <slot />
  </body>
</html>