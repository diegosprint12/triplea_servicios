---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ValueBar from '../components/ValueBar.astro';
import NosotrosSection from '../components/NosotrosSection.astro';
import ServiciosSection from '../components/ServiciosSection.astro';
import BannerEmergencia from '../components/BannerEmergencia.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<BaseLayout>
  <Header />

  <main>
    <Hero />

    <ScrollReveal>
      <ValueBar />
    </ScrollReveal>

    <ScrollReveal>
      <NosotrosSection />
    </ScrollReveal>

    <ScrollReveal>
      <ServiciosSection />
    </ScrollReveal>

    <ScrollReveal>
      <BannerEmergencia />
    </ScrollReveal>
  </main>

  <ScrollReveal>
    <Footer />
  </ScrollReveal>
</BaseLayout>
